# ============================================
# 🔐 API Keys — NUNCA commitear valores reales
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ============================================
# 🗄️ PostgreSQL + pgvector
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bancolombia_rag
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme_strong_password_here

# ============================================
# 🤖 Agent Service
# ============================================
AGENT_API_PORT=8000
AGENT_API_HOST=0.0.0.0
AGENT_LOG_LEVEL=INFO
AGENT_CORS_ORIGINS=http://localhost:4200

# ============================================
# 🔧 MCP Server
# ============================================
MCP_SERVER_PORT=8001
MCP_SERVER_HOST=0.0.0.0
MCP_TRANSPORT=stdio
MCP_LOG_LEVEL=INFO

# ============================================
# 🌐 Frontend
# ============================================
FRONTEND_PORT=4200
FRONTEND_API_URL=http://localhost:8000

# ============================================
# 🔍 Embeddings Configuration
# ============================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# ============================================
# 📄 Chunking Configuration
# ============================================
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNK_SEPARATORS=\n\n,\n,. , 

# ============================================
# 🕷️ Scraping Configuration
# ============================================
SCRAPING_BASE_URL=https://www.bancolombia.com/personas
SCRAPING_MAX_PAGES=500
SCRAPING_DELAY_SECONDS=2
SCRAPING_RESPECT_ROBOTS_TXT=true
SCRAPING_USER_AGENT=BancolombiaRAGBot/1.0

# ============================================
# 📦 Storage (S3/MinIO)
# ============================================
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=raw-html
S3_REGION=us-east-1

# ============================================
# 📨 Queue (Redis)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# 📊 Observability
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=bancolombia-rag
LOG_FORMAT=json
