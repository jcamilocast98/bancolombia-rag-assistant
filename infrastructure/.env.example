# ═══════════════════════════════════════════════════════
# 🔐 API Keys — NUNCA commitear valores reales
# ═══════════════════════════════════════════════════════
GEMINI_API_KEY="your_google_gemini_api_key_here"

# ═══════════════════════════════════════════════════════
# 🗄️ PostgreSQL + pgvector
# ═══════════════════════════════════════════════════════
POSTGRES_DB=bancolombia_rag
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme

# ═══════════════════════════════════════════════════════
# 🤖 Agent Service
# ═══════════════════════════════════════════════════════
AGENT_API_PORT=8000
AGENT_API_KEY=your_secure_api_key_here
AGENT_LOG_LEVEL=INFO
GEMINI_CHAT_MODEL=gemini-2.5-flash

# ═══════════════════════════════════════════════════════
# 🔧 MCP Server
# ═══════════════════════════════════════════════════════
MCP_SSE_URL=http://mcp-server:8001/mcp/sse/
MCP_TRANSPORT=sse
MCP_LOG_LEVEL=INFO
EMBEDDING_MODEL=models/gemini-embedding-001

# ═══════════════════════════════════════════════════════
# 🕷️ Scraping & Indexing
# ═══════════════════════════════════════════════════════
SCRAPING_BASE_URL=https://www.bancolombia.com/personas
SCRAPING_MAX_PAGES=100
SCRAPING_DELAY_SECONDS=1
MODELO_EMBEDDING_GEMINI=models/gemini-embedding-001

# ═══════════════════════════════════════════════════════
# 📦 Storage (S3/MinIO)
# ═══════════════════════════════════════════════════════
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
BUCKET_S3=bancolombia-raw-html

# ═══════════════════════════════════════════════════════
# 📊 Observability
# ═══════════════════════════════════════════════════════
LOG_FORMAT=json
